{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["sfo1"],
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "src/app/api/chat/route.ts":       { "maxDuration": 30 },
    "src/app/api/contact/route.ts":    { "maxDuration": 10 },
    "src/app/api/cotizacion/route.ts": { "maxDuration": 10 },
    "src/app/api/leads/route.ts":      { "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(), geolocation=(self), interest-cohort=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/productos",        "destination": "/soluciones",            "permanent": true },
    { "source": "/blog",             "destination": "/academia/blog",         "permanent": true },
    { "source": "/privacidad",       "destination": "/politica-privacidad",   "permanent": true }
  ]
}
